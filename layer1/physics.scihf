# ═══════════════════════════════════════════════════════════════
# Sci-hf 物理声明 — Kernel + Contingent + Laws + Corollaries
# ═══════════════════════════════════════════════════════════════
#
# 三层结构：
#   [kernel]     — 不可推导的物理内核，任何物理宇宙的框架
#   [contingent] — 我们这个宇宙的经验事实
#   [law]        — 从 kernel + contingent 推导的有效定律
#   [corollary]  — 从 law 推导的推论

# ── 词汇声明 ──────────────────────────────────────────────────

Q(time, [T], time)
Q(length, [L], geometric_length)
Q(mass, [M], inertial_mass)
Q(velocity, [L·T⁻¹], velocity)
Q(acceleration, [L·T⁻²], acceleration)
Q(momentum, [M·L·T⁻¹], momentum)
Q(force, [M·L·T⁻²], force)
Q(energy, [M·L²·T⁻²], energy)
Q(action, [M·L²·T⁻¹], action)
Q(angular_momentum, [M·L²·T⁻¹], angular_momentum)
Q(pressure, [M·L⁻¹·T⁻²], pressure)
Q(volume, [L³], volume)
Q(temperature, [Θ], thermodynamic_temperature)
Q(entropy, [M·L²·T⁻²·Θ⁻¹], entropy)
Q(internal_energy, [M·L²·T⁻²], thermodynamic_internal_energy)
Q(electric_charge, [T·I], electric_charge)
Q(electric_field, [M·L·T⁻³·I⁻¹], electric_field)
Q(magnetic_field, [M·T⁻²·I⁻¹], magnetic_flux_density)
Q(current_density, [L⁻²·I], current_density)
Q(charge_density, [L⁻³·T·I], charge_density)
Q(spin, [1], quantum_spin)
Q(probability_density, [L⁻³], quantum_probability_density)
Q(state_vector, [1], quantum_state)
Q(gravitational_mass, [M], gravitational_mass)
Q(spacetime_interval, [L²], spacetime_interval)
Q(metric_tensor, [1], metric_tensor)
Q(einstein_tensor, [L⁻²], einstein_tensor)
Q(stress_energy_tensor, [M·L⁻¹·T⁻²], stress_energy_tensor)
Q(color_charge, [1], color_charge)
Q(weak_isospin, [1], weak_isospin)
Q(weak_hypercharge, [1], weak_hypercharge)
Q(generation, [1], fermion_generation)
